# AlertFly 配置文件示例
# 复制此文件为 config.yaml 并根据实际环境修改

# Redis 配置
redis:
  enabled: true                  # 是否启用 Redis 消费者
  addr: "localhost:6379"        # Redis 服务地址
  password: ""                  # Redis 密码，无密码留空
  db: 0                         # Redis 数据库编号
  channel: "alerts"             # Pub/Sub 模式的 channel 名称
  # channel: "alert:*:*:*:*"     # 模式匹配：接收所有报警（PSUBSCRIBE）
  # channel: "alert:*:crm:*:critical"  # 模式匹配：CRM系统严重报警
  stream: "alert_stream"        # Stream 模式的 stream 名称
  consumer_group: "alertfly_group" # Stream 模式的 Consumer Group 名称
  mode: "pubsub"                # 消费模式：pubsub（Pub/Sub）或 stream（Stream）

# Kafka 配置
kafka:
  enabled: false                # 是否启用 Kafka 消费者
  version: "2.0.0"              # Kafka broker 版本（如 "0.10.0.0", "1.0.0", "2.0.0"）
  brokers:                      # Kafka broker 地址列表
    - "localhost:9092"
  # 订阅 topic，支持精确名称和正则匹配
  topics:                       # 多 topic 订阅（推荐）
    - "alert-events"                        # 精确订阅
    # - "regex:alert-.*"                    # 正则：所有 alert- 前缀的 topic
    # - "regex:^(deploy|monitor)-alerts$"   # 正则：指定前缀的 alerts topic
    # - "regex:alert\\..*"                  # 正则：订阅所有 alert topic
    # - "!regex:alert\\.deploy\\..*"        # 排除：排除 deploy 任务的报警
  # topic: "alerts"              # 单 topic 订阅（向后兼容，与 topics 二选一）
  group_id: "alertfly_group"    # Kafka Consumer Group ID
  topic_scan_interval: 30       # 正则 topic 扫描间隔（秒），默认 30

# 本地存储配置
storage:
  db_path: "./alertfly.db"      # SQLite 数据库文件路径
  retention_days: 7             # 消息保留天数，超过后自动清理
  max_records: 10000            # 最大保留记录数，超过后自动清理

# 桌面通知配置
notifier:
  enabled: true                 # 是否启用桌面弹窗通知

# 自动更新检查配置
updater:
  enabled: false                # 是否启用自动更新检查
  check_url: ""                 # 检查新版本信息的 URL
  interval: "24h"               # 检查间隔，Go duration 格式（如 1h, 24h, 30m）

# Web UI 配置
web:
  enabled: true                 # 是否启用 Web UI
  port: 18080                   # Web UI 监听端口

# 接收过滤配置（控制弹窗通知，不影响消息存储）
filter:
  missions: []                  # 接收的任务名列表，空=全部接收（如 ["deploy", "backup"]）
  senders: []                   # 接收的发送者列表，空=全部接收（如 ["ops", "dev"]）
  subtypes: []                  # 接收的子类型列表，空=全部接收（如 ["deploy", "alert"]）